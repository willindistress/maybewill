</Layout>

<script>
  const SCROLL_AMOUNT = 320;

  // Horizontal scroll arrows
  document.querySelectorAll<HTMLElement>('.wm-project').forEach((project) => {
    const strip = project.querySelector<HTMLElement>('.wm-strip')!;
    const prevBtn = project.querySelector<HTMLButtonElement>('.wm-arr--prev')!;
    const nextBtn = project.querySelector<HTMLButtonElement>('.wm-arr--next')!;

    function updateButtons() {
      prevBtn.disabled = strip.scrollLeft <= 0;
      nextBtn.disabled = strip.scrollLeft + strip.clientWidth >= strip.scrollWidth - 1;
    }

    prevBtn.addEventListener('click', () => strip.scrollBy({ left: -SCROLL_AMOUNT, behavior: 'smooth' }));
    nextBtn.addEventListener('click', () => strip.scrollBy({ left: SCROLL_AMOUNT, behavior: 'smooth' }));
    strip.addEventListener('scroll', updateButtons);
    updateButtons();
  });

  // More info modals
  document.querySelectorAll<HTMLButtonElement>('.wm-info-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const modal = document.getElementById(`modal-${btn.dataset.modal}`);
      modal?.classList.add('open');
    });
  });

  document.querySelectorAll<HTMLElement>('.wm-modal').forEach((modal) => {
    modal.querySelector('.wm-modal__close')?.addEventListener('click', () => {
      modal.classList.remove('open');
    });
    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.classList.remove('open');
    });
  });

  // Lightbox
  const lightbox = document.getElementById('wm-lightbox') as HTMLElement;
  const lightboxImg = document.getElementById('wm-lightbox-img') as HTMLImageElement;
  const prevBtn = document.getElementById('wm-lightbox-prev') as HTMLButtonElement;
  const nextBtn = document.getElementById('wm-lightbox-next') as HTMLButtonElement;

  let currentImages: HTMLImageElement[] = [];
  let currentIndex = 0;

  function showImage(index: number) {
    currentIndex = index;
    lightboxImg.src = currentImages[index].src;
    lightboxImg.alt = currentImages[index].alt;
    prevBtn.disabled = index === 0;
    nextBtn.disabled = index === currentImages.length - 1;
  }

  document.querySelectorAll<HTMLElement>('.wm-project').forEach((project) => {
    const imgs = Array.from(project.querySelectorAll<HTMLImageElement>('.wm-strip__img'));
    imgs.forEach((img, i) => {
      img.style.cursor = 'pointer';
      img.addEventListener('click', () => {
        currentImages = imgs;
        showImage(i);
        lightbox.classList.add('open');
      });
    });
  });

  prevBtn.addEventListener('click', (e) => { e.stopPropagation(); showImage(currentIndex - 1); });
  nextBtn.addEventListener('click', (e) => { e.stopPropagation(); showImage(currentIndex + 1); });

  function closeLightbox() {
    lightbox.classList.remove('open');
  }

  document.getElementById('wm-lightbox-back')!.addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });
</script>
