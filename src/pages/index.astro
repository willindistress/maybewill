---
import Layout from "../layouts/Layout.astro";
import "../styles/index.css";
---

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <Layout title="will donnell!">
  <header class="header">
    <h1 class="title">Will Donnell</h1>
    <p class="tagline">Graphic Designer / Jesus Follower</p>
  </header>

  <div class="image-wrap" id="image-wrap">
    <img src="/willmain.png" alt="if you're reading this, it means my site is broken. my face should be here. text me?">
  </div>

  <div class="about-overlay" id="about-overlay" aria-hidden="true">
    <div class="about-overlay__content">
      <div class="about-overlay__box" id="about-overlay-box">
        <div class="body-copy">
          <p style="text-align: center;">i'm will! great to meet you.</p>
          <p class="indent-first" style="text-align: justify">i'm a 23 year old graphic designer based in Dallas. i'm passionate about where art and ministry meet, and how design can reach people for the Gospel and expand the kingdom of Heaven.</p>
          <p class="indent-first" style="text-align: justify">with experience in programs such as adobe photoshop, illustrator, and after effects, as well as marketing and design roles in campus ministries, i want to blend artistic function and creative service with the life-changing news of Jesus.</p>
          <p class="indent-first" style="text-align: justify">i love people, diet coke with lime, dancefloors, watching movies, wired headphones, serif typefaces, and this love by maroon 5.</p>
          <p style="text-align: center">you can find me in these places:</p>
          <div class="body-copy__links">
            <a href="mailto:willdonell8@gmail.com">email</a>
            <a href="https://instagram.com/wlldnnll" target="_blank" rel="noopener noreferrer">instagram</a>
            <a href="https://www.linkedin.com/in/willdonnell8/" target="_blank" rel="noopener noreferrer">linkedin</a>
          </div>
        </div>
      </div>
      <div class="about-overlay__gifs" aria-hidden="true">
        <img src="/framesbutton.gif" alt="">
        <img src="/hedied4u.gif" alt="">
        <img src="/macos8button.gif" alt="">
      </div>
    </div>
  </div>

  <nav class="nav">
    <a href="#" id="about-link">About</a>
    <a href="/squashed">Portfolio</a>
    <a href="https://www.linkedin.com/in/willdonnell8/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
  </nav>

  <script>
    (function () {
      const FONTS = [
        '"Helvetica Neue", Helvetica, Arial, sans-serif',
        'Georgia, "Times New Roman", serif',
        '"Palatino Linotype", "Book Antiqua", Palatino, serif',
        'Verdana, Geneva, sans-serif',
        '"Trebuchet MS", "Lucida Grande", sans-serif',
        '"Courier New", Courier, monospace',
        'Impact, "Haettenschweiler", sans-serif',
        '"Gill Sans", "Gill Sans MT", Calibri, sans-serif'
      ];

      function wrapLetters(link: Element) {
        const text = link.textContent;
        link.textContent = '';
        for (let i = 0; i < text.length; i++) {
          const span = document.createElement('span');
          span.className = 'char';
          span.textContent = text[i];
          link.appendChild(span);
        }
      }

      function randomFont() {
        return FONTS[Math.floor(Math.random() * FONTS.length)];
      }

      function randomCase(ch: string) {
        return Math.random() > 0.5 ? ch.toUpperCase() : ch.toLowerCase();
      }

      function applyHoverStyle(link: { querySelectorAll: (arg0: string) => any[]; }) {
        link.querySelectorAll('.char').forEach(function (char: { style: { fontFamily: string; }; textContent: any; }) {
          char.style.fontFamily = randomFont();
          char.textContent = randomCase(char.textContent);
        });
      }

      function resetLinkStyle(link: { getAttribute: (arg0: string) => string; querySelectorAll: (arg0: string) => any[]; }) {
        var upper = link.getAttribute('data-original') || '';
        link.querySelectorAll('.char').forEach(function (char: { style: { fontFamily: string; }; textContent: any; }, i: string | number) {
          char.style.fontFamily = '';
          if (upper[i]) char.textContent = upper[i];
        });
      }

      document.querySelectorAll('.nav a').forEach(function (link) {
        var original = link.textContent;
        link.setAttribute('data-original', original);
        wrapLetters(link);

        link.addEventListener('mouseenter',  () => {
          applyHoverStyle(this);
        });

        link.addEventListener('mouseleave',  () => {
          resetLinkStyle(this);
        });
      });

      var aboutLink = document.getElementById('about-link');
      var aboutOverlay = document.getElementById('about-overlay');
      var aboutOverlayBox = document.getElementById('about-overlay-box');
      if (aboutLink && aboutOverlay) {
        aboutLink.addEventListener('click', function (e) {
          e.preventDefault();
          aboutOverlay.classList.toggle('visible');
          aboutOverlay.setAttribute('aria-hidden', aboutOverlay.classList.contains('visible') ? 'false' : 'true');
        });
        aboutOverlay.addEventListener('click', function (e) {
          if (e.target === aboutOverlay) {
            aboutOverlay.classList.remove('visible');
            aboutOverlay.setAttribute('aria-hidden', 'true');
          }
        });
        if (aboutOverlayBox) {
          aboutOverlayBox.addEventListener('click', function (e) {
            e.stopPropagation();
          });
        }
      }
      
      var wrap = document.getElementById('image-wrap');
      var body = document.body;
      var hoverLocked = false;
      var cursorOverImage = false;

      wrap.addEventListener('mouseenter', function () {
        cursorOverImage = true;
        if (!hoverLocked) {
          body.classList.add('image-hover');
        } else {
          body.classList.add('locked-hover');
        }
      });
      wrap.addEventListener('mouseleave', function () {
        cursorOverImage = false;
        if (!hoverLocked) {
          body.classList.remove('image-hover');
        } else {
          body.classList.remove('locked-hover');
        }
      });

      wrap.addEventListener('click', function () {
        hoverLocked = !hoverLocked;
        if (hoverLocked) {
          body.classList.add('image-hover');
        } else {
          body.classList.remove('image-hover');
          body.classList.remove('locked-hover');
        }
        wrap.classList.add('bounce');
        if (cursorOverImage) wrap.classList.add('bounce-to-hover');
        wrap.addEventListener('animationend', function removeBounce() {
          wrap.classList.remove('bounce');
          wrap.classList.remove('bounce-to-hover');
          wrap.removeEventListener('animationend', removeBounce);
        });
      });
    })();

  document.addEventListener('DOMContentLoaded', () => {
    const title = document.querySelector('.title');
    const image = document.querySelector('.image-wrap');

    if (!title || !image) return;

    // Wrap each letter in a span
    const text = title.textContent;
    title.textContent = '';

    [...text].forEach(letter => {
      const span = document.createElement('span');
      span.classList.add('char');
      span.textContent = letter === ' ' ? '\u00A0' : letter;
      title.appendChild(span);
    });

    const letters = Array.from(document.querySelectorAll('.title .char'));
    let interval;
    let settledCount = 0;
    let decoded = false;
    let isHovering = false;

    function startDecode() {
      settledCount = 0;
      letters.forEach(l => l.classList.remove('serif'));

      interval = setInterval(() => {
        if (settledCount >= letters.length) {
          clearInterval(interval);
          return;
        }

        const unsettled = letters.filter(l => !l.classList.contains('serif'));
        const randomLetter = unsettled[Math.floor(Math.random() * unsettled.length)];

        if (randomLetter) {
          randomLetter.classList.add('serif');
          settledCount++;
        }
      }, 35); /* lower - snappier, higher - slower */
    }

    function resetLetters() {
      clearInterval(interval);

      let revertedCount = 0;

      interval = setInterval(() => {
        if (revertedCount >= letters.length) {
          clearInterval(interval);
          return;
        }

        const settled = letters.filter(l => l.classList.contains('serif'));
        const randomLetter = settled[Math.floor(Math.random() * settled.length)];

        if (randomLetter) {
          randomLetter.classList.remove('serif');
          revertedCount++;
        }
      }, 35);
    }

    image.addEventListener('mouseenter', () => {
      isHovering = true;
      startDecode();
    });

    image.addEventListener('mouseleave', () => {
      isHovering = false;
      resetLetters();
    });

    image.addEventListener('click', () => {
      // If user is hovering (desktop), do nothing
      if (isHovering) return;

      if (decoded) {
        resetLetters();
      } else {
        startDecode();
      }
      decoded = !decoded;
    });
  });
  </script>
</Layout>
